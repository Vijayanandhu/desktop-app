<Page x:Class="EnterpriseWorkReport.Views.Pages.ProjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Project Management" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Create and manage projects with custom report fields and billing formulas."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="AddProjectBtn" Content="+ New Project"
                            Style="{StaticResource PrimaryButton}" Padding="16,9" FontSize="13"
                            Click="AddProject_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="SearchBox" Style="{StaticResource ModernTextBox}"
                             Width="220" Padding="10,8"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="-30,0,12,0" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Projects Table -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="ProjectsGrid" Style="{StaticResource ModernDataGrid}"
                      SelectionChanged="ProjectsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Project Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                    <DataGridTextColumn Header="Billing Formula" Binding="{Binding BillingFormula}" Width="*"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource BadgeSuccess}" HorizontalAlignment="Left"
                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Active" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Fields" Tag="{Binding Id}"
                                            Style="{StaticResource OutlineButton}" Padding="10,5" FontSize="12"
                                            Margin="0,0,6,0" Click="ManageFields_Click"/>
                                    <Button Content="Edit" Tag="{Binding Id}"
                                            Style="{StaticResource PrimaryButton}" Padding="10,5" FontSize="12"
                                            Click="EditProject_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
