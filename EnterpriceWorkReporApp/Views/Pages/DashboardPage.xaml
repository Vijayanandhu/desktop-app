<Page x:Class="EnterpriseWorkReport.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Background="{DynamicResource AppBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Title -->
            <TextBlock Text="Analytics Overview" Style="{StaticResource PageTitle}"/>
            <TextBlock x:Name="SubtitleText" Style="{StaticResource PageSubtitle}" Margin="0,4,0,24"/>

            <!-- KPI Cards Row -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="📝" FontSize="28"/>
                        <TextBlock x:Name="TotalReportsText" Text="0" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Total Reports" Style="{StaticResource FieldLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="₹" FontSize="28" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock x:Name="TotalBillingText" Text="₹0.00" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Total Billing" Style="{StaticResource FieldLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="28"/>
                        <TextBlock x:Name="TotalEmployeesText" Text="0" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Active Employees" Style="{StaticResource FieldLabel}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="28"/>
                        <TextBlock x:Name="TotalProjectsText" Text="0" FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,8,0,4"/>
                        <TextBlock Text="Active Projects" Style="{StaticResource FieldLabel}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts Section -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="📈 Weekly Billing Trend" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <lvc:CartesianChart x:Name="BillingChart" Height="220" LegendLocation="None" Hoverable="True">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Days" Labels="{Binding ChartLabels}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Amount" LabelFormatter="{Binding ChartFormatter}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="📊 Project Distribution" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <lvc:PieChart x:Name="ProjectPieChart" Height="220" LegendLocation="Bottom" Hoverable="True" InnerRadius="40"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Second row: Recent Reports + Top Employees -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Reports -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Recent Work Reports" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <DataGrid x:Name="RecentReportsGrid" Style="{StaticResource ModernDataGrid}"
                                  MaxHeight="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                                <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="*"/>
                                <DataGridTextColumn Header="Object ID" Binding="{Binding ObjectId}" Width="*"/>
                                <DataGridTextColumn Header="Billing" Binding="{Binding BillingAmount, StringFormat='₹{0:F2}'}" Width="100"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding SubmissionDate, StringFormat='dd/MM/yyyy'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Top Employees -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="🏆 Top Performers" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <ItemsControl x:Name="TopEmployeesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FullName}"
                                                       VerticalAlignment="Center" FontSize="13"/>
                                            <TextBlock Grid.Column="2" Text="{Binding BillingTotal, StringFormat='₹{0:F0}'}"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Attendance Summary -->
            <Border Style="{StaticResource CardBorder}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Today's Attendance" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <UniformGrid Columns="4">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="PresentCountText" Text="0" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Present" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="AbsentCountText" Text="0" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Absent" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="HalfDayCountText" Text="0" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Half Day" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="LeaveCountText" Text="0" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="On Leave" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
