<Page x:Class="EnterpriseWorkReport.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Manage system settings, themes, and database operations."
                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,24"/>

            <!-- Personalization (Themes) -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🎨 Personalization &amp; Themes" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Choose your preferred application theme" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <RadioButton x:Name="ThemeLightRadio" Content="☀️ Light" Margin="0,0,24,0" 
                                     Foreground="{DynamicResource TextPrimaryBrush}" IsChecked="True"
                                     Checked="Theme_Checked"/>
                        <RadioButton x:Name="ThemeNavyRadio" Content="🌑 Deep Navy" Margin="0,0,24,0" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="Theme_Checked"/>
                        <RadioButton x:Name="ThemeAmoledRadio" Content="🖤 AMOLED Black" 
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Checked="Theme_Checked" ToolTip="High contrast, true black"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Network Server (LAN Access) -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🌐 Network Server (LAN Access)" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enable network access for other computers" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="ServerStatusText" Text="Server is NOT running"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock Text="Other users can access this info page via browser on their computers."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,8,16,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button x:Name="StartServerBtn" Content="▶ Start Server" Style="{StaticResource PrimaryButton}"
                                    Padding="20,10" FontSize="13" Click="StartServer_Click"/>
                            <Button x:Name="StopServerBtn" Content="⏹ Stop Server" Style="{StaticResource DangerButton}"
                                    Padding="20,10" FontSize="13" Margin="0,8,0,0" Click="StopServer_Click"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                    <Border x:Name="ServerUrlsPanel" Visibility="Collapsed" Background="#f0f7ff" 
                            CornerRadius="8" Padding="16" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Access URLs (share with other users):" FontWeight="SemiBold" 
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="ServerUrlsText" Text="" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Backup & Restore -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💾 Database Backup &amp; Restore" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Create Backup" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="Creates a timestamped copy of the database in the backups folder."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="🗄 Backup Now" Style="{StaticResource PrimaryButton}"
                                    Padding="16,9" FontSize="13" HorizontalAlignment="Left"
                                    Click="BackupNow_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Restore From Backup" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="Select a backup file to restore the database. Current data will be replaced."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="📂 Restore Backup" Style="{StaticResource DangerButton}"
                                    Padding="16,9" FontSize="13" HorizontalAlignment="Left"
                                    Click="RestoreBackup_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="BackupStatusText" Text="" FontSize="12"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Audit Log Viewer -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📋 Audit Log" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="🔄 Refresh" Style="{StaticResource OutlineButton}"
                                Padding="12,5" FontSize="12" Margin="16,0,0,0"
                                Click="RefreshAuditLog_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="AuditGrid" Style="{StaticResource ModernDataGrid}" MaxHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='dd/MM/yyyy HH:mm'}" Width="160"/>
                            <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="*"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Company Settings -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🏢 Company Settings" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,12">
                            <TextBlock Text="Company Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CompanyNameBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CompanyEmailBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,16,12">
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CompanyPhoneBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock Text="Tax ID" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TaxIdBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,16,0">
                            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CompanyAddressBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="Currency Symbol" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CurrencyBox" Style="{StaticResource ModernTextBox}" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="Company Logo" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}" 
                                    Background="#FAFAFA" CornerRadius="4" Width="80" Height="80" Margin="0,0,16,0">
                                <Image x:Name="SettingsLogoImage" Stretch="Uniform" Margin="4"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <Button Content="Upload Logo" Style="{StaticResource OutlineButton}" 
                                        Click="UploadLogo_Click" Padding="12,6" FontSize="12" HorizontalAlignment="Left"/>
                                <TextBlock Text="Recommended size: 200x200 PNG or JPG" 
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="💾 Save Company Settings" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,16,0,0" Padding="20,10"
                            Click="SaveCompanySettings_Click"/>
                    <TextBlock x:Name="CompanyStatusText" Text="" FontSize="12"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Developer / Demo Mode -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🛠 Developer / Demo Mode" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Reset &amp; Load Demo Data" Style="{StaticResource FieldLabel}" Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="WARNING: This will delete ALL current data and populate the system with realistic demo users, projects, and work reports."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,4,16,0"/>
                        </StackPanel>
                        <Button x:Name="LoadDemoBtn" Grid.Column="1" Content="🚀 Load Demo Data" Style="{StaticResource DangerButton}"
                                Padding="20,10" FontSize="13" VerticalAlignment="Center"
                                Click="LoadDemo_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="ℹ About" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="Enterprise Work Report System" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Version 1.0.0  •  Built with .NET Framework 4.8 + WPF + SQLite"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4"/>
                    <TextBlock Text="A complete workforce management platform for data services companies."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
