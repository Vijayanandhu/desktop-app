<Page x:Class="EnterpriseWorkReport.Views.Pages.LeaderboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="🏆 Leaderboard" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Rankings based on billing value, work volume, quality score, and attendance."
                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,20"/>

            <!-- Period Filter -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Period:" VerticalAlignment="Center" Margin="0,0,10,0"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <ComboBox x:Name="PeriodSelector" Style="{StaticResource ModernComboBox}"
                              Width="180" SelectionChanged="Period_Changed">
                        <ComboBoxItem Content="Today"/>
                        <ComboBoxItem Content="This Week"/>
                        <ComboBoxItem Content="This Month"/>
                        <ComboBoxItem Content="All Time"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Top 3 Podium -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Top Performers by Billing" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                    <UniformGrid Columns="3" Rows="1">
                        <!-- 2nd Place -->
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,8,0" HorizontalAlignment="Center">
                            <Border Background="#E5E7EB" CornerRadius="50" Width="56" Height="56"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="Rank2Initial" Text="?" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="🥈" FontSize="28" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock x:Name="Rank2Name" Text="—" FontWeight="SemiBold" FontSize="13"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="Rank2Billing" Text="₹0" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"/>
                        </StackPanel>
                        <!-- 1st Place -->
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="50"
                                    Width="70" Height="70" HorizontalAlignment="Center">
                                <TextBlock x:Name="Rank1Initial" Text="?" FontSize="28" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="🥇" FontSize="36" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock x:Name="Rank1Name" Text="—" FontWeight="Bold" FontSize="15"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="Rank1Billing" Text="₹0" FontSize="14"
                                       Foreground="{StaticResource SuccessBrush}" TextAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <!-- 3rd Place -->
                        <StackPanel VerticalAlignment="Bottom" Margin="8,0,0,0" HorizontalAlignment="Center">
                            <Border Background="#FEF3C7" CornerRadius="50" Width="56" Height="56"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="Rank3Initial" Text="?" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="🥉" FontSize="28" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock x:Name="Rank3Name" Text="—" FontWeight="SemiBold" FontSize="13"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="Rank3Billing" Text="₹0" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Full Rankings Table -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
                <DataGrid x:Name="LeaderboardGrid" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="60"/>
                        <DataGridTextColumn Header="Employee" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Total Billing" Binding="{Binding BillingTotal, StringFormat='₹{0:F2}'}" Width="150"/>
                        <DataGridTextColumn Header="Reports Count" Binding="{Binding ReportCount}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
