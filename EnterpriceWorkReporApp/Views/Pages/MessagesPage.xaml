<Page x:Class="EnterpriseWorkReport.Views.Pages.MessagesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="💬 Messages" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Send and receive messages, files, and images."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="ComposeBtn" Content="✉️ New Message"
                            Style="{StaticResource PrimaryButton}" Padding="16,9" FontSize="13"
                            Click="Compose_Click"/>
                    <Button Content="📥 Inbox" Style="{StaticResource OutlineButton}" 
                            Padding="16,9" FontSize="13" Margin="10,0,0,0" Click="Inbox_Click"/>
                    <Button Content="📤 Sent" Style="{StaticResource OutlineButton}" 
                            Padding="16,9" FontSize="13" Margin="10,0,0,0" Click="Sent_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Mark All Read" Style="{StaticResource OutlineButton}"
                            Padding="12,8" FontSize="12" Click="MarkAllRead_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages List -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <DataGrid x:Name="MessagesGrid" Style="{StaticResource ModernDataGrid}"
                          SelectionChanged="MessagesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="📩" FontSize="16" HorizontalAlignment="Center"
                                               Visibility="{Binding IsRead, Converter={StaticResource InverseBoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="From" Binding="{Binding SenderName}" Width="150"/>
                        <DataGridTextColumn Header="To" Binding="{Binding ReceiverName}" Width="150"/>
                        <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='dd/MM HH:mm'}" Width="120"/>
                        <DataGridTemplateColumn Header="Attachment" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="📎" FontSize="14" HorizontalAlignment="Center"
                                               Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibility}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="View" Tag="{Binding Id}"
                                                Style="{StaticResource OutlineButton}" Padding="8,4" FontSize="11"
                                                Margin="0,0,4,0" Click="ViewMessage_Click"/>
                                        <Button Content="Delete" Tag="{Binding Id}"
                                                Style="{StaticResource DangerButton}" Padding="8,4" FontSize="11"
                                                Click="DeleteMessage_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                
                <TextBlock x:Name="EmptyText" Text="No messages found"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>
