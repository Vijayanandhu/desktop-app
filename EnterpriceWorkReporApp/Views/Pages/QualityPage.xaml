<Page x:Class="EnterpriseWorkReport.Views.Pages.QualityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Quality Reports" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Upload and track employee quality metrics: Accuracy, Error Rate, Rework Count, Quality Score."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Path Configuration -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Path Configuration Row -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Report Folder:" VerticalAlignment="Center" 
                           Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ReportPathBox" Style="{StaticResource ModernTextBox}"
                         Text="{Binding QualityReportsPath, Mode=TwoWay}" Margin="0,0,10,0"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="SavePath_Click_Btn" Content="Save Path" Style="{StaticResource PrimaryButton}"
                        Padding="12,8" Click="SavePath_Click"/>
                
                <!-- Date Selection Row -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Select Date:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <DatePicker x:Name="FilterDate" Width="130" Margin="0,0,10,0" SelectedDateChanged="Filter_Changed"/>
                    <DatePicker x:Name="FilterDateTo" Width="130" Margin="0,0,10,0" SelectedDateChanged="Filter_Changed"/>
                    
                    <Button x:Name="AddQualityBtn" Content="+ Add Quality Report" Style="{StaticResource PrimaryButton}"
                            Padding="14,9" FontSize="13" Margin="0,0,10,0" Click="AddQuality_Click"/>
                    <Button x:Name="ImportBtn" Content="📁 Import CSV/Excel" Style="{StaticResource OutlineButton}"
                            Padding="14,9" FontSize="13" Margin="0,0,10,0" Click="ImportFile_Click"/>
                    
                    <TextBox x:Name="FilterEmployeeName" Style="{StaticResource ModernTextBox}" Width="150" Margin="0,0,10,0"
                             Tag="Employee Name" ToolTip="Employee Name" TextChanged="Filter_Changed" />
                    
                    <Button Content="Clear" Style="{StaticResource OutlineButton}" Padding="12,9" FontSize="13"
                            Click="ClearFilter_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="QualityGrid" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="EmployeeCol" Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding ReportDate, StringFormat='dd/MM/yyyy'}" Width="120"/>
                    <DataGridTextColumn Header="Accuracy%" Binding="{Binding Accuracy, StringFormat='{}{0:F1}%'}" Width="120"/>
                    <DataGridTextColumn Header="Error Rate%" Binding="{Binding ErrorRate, StringFormat='{}{0:F1}%'}" Width="120"/>
                    <DataGridTextColumn Header="Rework Count" Binding="{Binding ReworkCount}" Width="120"/>
                    <DataGridTextColumn Header="Quality Score" Binding="{Binding QualityScore, StringFormat='{}{0:F1}'}" Width="120"/>
                    <DataGridTemplateColumn x:Name="ActionsCol" Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit" Tag="{Binding Id}" Style="{StaticResource PrimaryButton}"
                                            Padding="10,5" FontSize="12" Margin="0,0,6,0" Click="EditQuality_Click"/>
                                    <Button Content="🗑" Tag="{Binding Id}" Style="{StaticResource DangerButton}"
                                            Padding="10,5" FontSize="12" Click="DeleteQuality_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
