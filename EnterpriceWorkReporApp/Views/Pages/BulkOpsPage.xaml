<Page x:Class="EnterpriseWorkReport.Views.Pages.BulkOpsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Bulk Operations" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Upload data in bulk via CSV, Excel, TXT, JSON, or XML files. Download templates to get started."
                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,24"/>

            <UniformGrid Columns="2">
                <!-- Bulk Work Reports -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="📝 Work Reports" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Import multiple work reports at once from a CSV file."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬇ Template" Style="{StaticResource OutlineButton}"
                                    Padding="12,8" FontSize="13" Margin="0,0,8,0"
                                    Click="DownloadTemplate_Click" Tag="WorkReports"/>
                            <Button Content="📁 Import" Style="{StaticResource PrimaryButton}"
                                    Padding="12,8" FontSize="13"
                                    Click="ImportFile_Click" Tag="WorkReports"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bulk Attendance -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📅 Attendance" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Upload attendance records for multiple employees."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬇ Template" Style="{StaticResource OutlineButton}"
                                    Padding="12,8" FontSize="13" Margin="0,0,8,0"
                                    Click="DownloadTemplate_Click" Tag="Attendance"/>
                            <Button Content="📁 Import" Style="{StaticResource PrimaryButton}"
                                    Padding="12,8" FontSize="13"
                                    Click="ImportFile_Click" Tag="Attendance"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bulk Quality -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="⭐ Quality Reports" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Upload quality scores for multiple employees at once."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬇ Template" Style="{StaticResource OutlineButton}"
                                    Padding="12,8" FontSize="13" Margin="0,0,8,0"
                                    Click="DownloadTemplate_Click" Tag="Quality"/>
                            <Button Content="📁 Import" Style="{StaticResource PrimaryButton}"
                                    Padding="12,8" FontSize="13"
                                    Click="ImportFile_Click" Tag="Quality"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bulk Users -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="👥 User Creation" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Create multiple employee accounts from a CSV file."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬇ Template" Style="{StaticResource OutlineButton}"
                                    Padding="12,8" FontSize="13" Margin="0,0,8,0"
                                    Click="DownloadTemplate_Click" Tag="Users"/>
                            <Button Content="📁 Import" Style="{StaticResource PrimaryButton}"
                                    Padding="12,8" FontSize="13"
                                    Click="ImportFile_Click" Tag="Users"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Import Log -->
            <Border Style="{StaticResource CardBorder}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Import Log" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ImportLogText" Text="No imports yet." FontSize="12" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
