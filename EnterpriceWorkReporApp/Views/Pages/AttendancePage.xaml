<Page x:Class="EnterpriseWorkReport.Views.Pages.AttendancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBgBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Attendance Management" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Track employee attendance. Statuses: Present, Absent, Half Day, Leave."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="ClockInBtn" Content="🕐 Clock In" Style="{StaticResource SuccessButton}"
                            Padding="14,9" FontSize="13" Margin="0,0,10,0" Click="ClockIn_Click"/>
                    <Button x:Name="ClockOutBtn" Content="🕒 Clock Out" Style="{StaticResource WarningButton}"
                            Padding="14,9" FontSize="13" Margin="0,0,10,0" Click="ClockOut_Click"/>
                    <Button Content="+ Manual Entry" Style="{StaticResource PrimaryButton}"
                            Padding="14,9" FontSize="13" Margin="0,0,10,0" Click="MarkAttendance_Click"/>
                            
                    <!-- Filter Controls -->
                    <TextBox x:Name="FilterEmployeeName" Style="{StaticResource ModernTextBox}" Width="150" Margin="0,0,10,0"
                             Tag="Employee Name" ToolTip="Employee Name" TextChanged="Filter_Changed" />
                    <DatePicker x:Name="FilterDate" Width="130" Margin="0,0,10,0"
                                SelectedDateChanged="Filter_Changed"/>
                    <ComboBox x:Name="FilterStatus" Style="{StaticResource ModernComboBox}"
                              Width="160" Margin="0,0,10,0" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Statuses"/>
                        <ComboBoxItem Content="Present"/>
                        <ComboBoxItem Content="Absent"/>
                        <ComboBoxItem Content="Half Day"/>
                        <ComboBoxItem Content="Leave"/>
                    </ComboBox>
                    <Button Content="Clear" Style="{StaticResource OutlineButton}" Padding="12,9" FontSize="13"
                            Click="ClearFilter_Click"/>
                </StackPanel>
                <Button Content="⬇ Export" Style="{StaticResource OutlineButton}" HorizontalAlignment="Right"
                        Padding="14,9" FontSize="13" Click="Export_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="AttendanceGrid" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="EmployeeCol" Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd/MM/yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime, StringFormat='hh:mm tt'}" Width="90"/>
                    <DataGridTextColumn Header="Clock Out" Binding="{Binding ClockOutTime, StringFormat='hh:mm tt'}" Width="90"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn x:Name="ActionsCol" Header="Actions" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit" Tag="{Binding Id}" Style="{StaticResource PrimaryButton}"
                                            Padding="10,5" FontSize="12" Margin="0,0,6,0" Click="EditAttendance_Click"/>
                                    <Button Content="🗑" Tag="{Binding Id}" Style="{StaticResource DangerButton}"
                                            Padding="10,5" FontSize="12" Click="DeleteAttendance_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
