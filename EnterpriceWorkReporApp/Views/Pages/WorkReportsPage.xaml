<Page x:Class="EnterpriseWorkReport.Views.Pages.WorkReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBgBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Work Reports" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Submit and manage daily work reports." Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="+ Submit Report" Style="{StaticResource PrimaryButton}"
                            Padding="16,9" FontSize="13" Margin="0,0,10,0" Click="AddReport_Click"/>
                    <!-- Filter Controls -->
                    <TextBox x:Name="FilterEmployeeName" Style="{StaticResource ModernTextBox}" Width="150" Margin="0,0,10,0"
                             Tag="Employee Name" ToolTip="Employee Name" TextChanged="Filter_Changed" />
                    <ComboBox x:Name="FilterProject" Style="{StaticResource ModernComboBox}"
                              Width="180" Margin="0,0,10,0" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Projects"/>
                    </ComboBox>
                    <DatePicker x:Name="FilterDateFrom" Width="130" Margin="0,0,10,0"
                                SelectedDateChanged="Filter_Changed"/>
                    <DatePicker x:Name="FilterDateTo" Width="130" Margin="0,0,10,0"
                                SelectedDateChanged="Filter_Changed"/>
                    <Button Content="Clear" Style="{StaticResource OutlineButton}" Padding="12,9" FontSize="13"
                            Click="ClearFilter_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ExportSummaryBtn" Content="📋 Summary PDF" Style="{StaticResource OutlineButton}"
                            Padding="14,9" FontSize="13" Click="ExportSummaryPdf_Click" Margin="0,0,10,0"/>
                    <Button x:Name="ExportDetailedBtn" Content="📄 Detailed PDF" Style="{StaticResource OutlineButton}"
                            Padding="14,9" FontSize="13" Click="ExportDetailedPdf_Click" Margin="0,0,10,0"/>
                    <Button Content="⬇ Export CSV" Style="{StaticResource OutlineButton}"
                            Padding="14,9" FontSize="13" Click="ExportCsv_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="ReportsGrid" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn x:Name="EmployeeCol" Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                    <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="*"/>
                    <DataGridTextColumn Header="Object ID" Binding="{Binding ObjectId}" Width="*"/>
                    <DataGridTextColumn Header="Billing" Binding="{Binding BillingAmount, StringFormat='₹{0:F2}'}" Width="100"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding SubmissionDate, StringFormat='dd/MM/yyyy'}" Width="110"/>
                    <DataGridTemplateColumn x:Name="ActionsCol" Header="Actions" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📎" Tag="{Binding AttachmentPath}" Style="{StaticResource OutlineButton}"
                                            Padding="8,5" FontSize="12" Margin="0,0,6,0" Click="ViewAttachment_Click"
                                            Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVis}}"
                                            ToolTip="Open Attachment"/>
                                    <Button Content="Edit" Tag="{Binding Id}" Style="{StaticResource PrimaryButton}"
                                            Padding="10,5" FontSize="12" Margin="0,0,6,0" Click="EditReport_Click"/>
                                    <Button Content="🗑" Tag="{Binding Id}" Style="{StaticResource DangerButton}"
                                            Padding="10,5" FontSize="12" Click="DeleteReport_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
