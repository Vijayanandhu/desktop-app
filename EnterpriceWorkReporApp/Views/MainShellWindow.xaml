<Window x:Class="EnterpriseWorkReport.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enterprise Work Report System"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}"
        ResizeMode="CanResizeWithGrip"
        WindowState="Normal">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20"
                        BorderBrush="#2A2E45" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CompanyLogoBorder" Background="{StaticResource PrimaryBrush}" CornerRadius="8"
                                    Width="34" Height="34">
                                <Grid>
                                    <TextBlock x:Name="CompanyLogoTextFallback" Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image x:Name="CompanyLogoImage" Stretch="Uniform" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="CompanyNameText" Text="WorkReport" FontSize="14" FontWeight="Bold"
                                           Foreground="White" TextWrapping="Wrap" MaxWidth="120"/>
                                <TextBlock Text="System" FontSize="10"
                                           Foreground="{StaticResource SidebarTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- User Info -->
                <Border DockPanel.Dock="Bottom" Padding="20,14"
                        BorderBrush="#2A2E45" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border x:Name="ProfilePicBorder" Background="{StaticResource PrimaryBrush}" CornerRadius="20"
                                    Width="36" Height="36" ClipToBounds="True">
                                <Grid>
                                    <TextBlock x:Name="UserInitialText" Text="A" FontSize="16"
                                               FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image x:Name="UserProfileImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="UserFullNameText" Text="Admin User" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="UserRoleText" Text="Administrator" FontSize="11"
                                           Foreground="{StaticResource SidebarTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="👤  My Profile" Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Click="Profile_Click"
                                Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,5"/>
                        <Button Content="⇐  Sign Out" Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Click="SignOut_Click"
                                Foreground="{StaticResource DangerBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,16,12,0" x:Name="NavPanel">
                        <TextBlock Text="MENU" FontSize="10" FontWeight="Bold"
                                   Foreground="#4A5568" Margin="8,0,0,8"/>

                        <Button x:Name="NavDashboard" Content="⬜  Dashboard"
                                Style="{StaticResource SidebarNavButtonActive}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Dashboard" Click="NavButton_Click"/>

                        <Button x:Name="NavProjects" Content="📁  Projects"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Projects" Click="NavButton_Click"/>

                        <Button x:Name="NavWorkReports" Content="📝  Work Reports"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="WorkReports" Click="NavButton_Click"/>

                        <Button x:Name="NavBilling" Content="₹  Billing"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Billing" Click="NavButton_Click"/>

                        <Button x:Name="NavAttendance" Content="📅  Attendance"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Attendance" Click="NavButton_Click"/>

                        <Button x:Name="NavLeave" Content="🏖  Leave"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Leave" Click="NavButton_Click"/>

                        <Button x:Name="NavQuality" Content="⭐  Quality Reports"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Quality" Click="NavButton_Click"/>

                        <Button x:Name="NavLeaderboard" Content="🏆  Leaderboard"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Leaderboard" Click="NavButton_Click"/>

                        <Button x:Name="NavMessages" Content="💬  Messages"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Messages" Click="NavButton_Click"/>

                        <TextBlock Text="ADMIN" FontSize="10" FontWeight="Bold"
                                   Foreground="#4A5568" Margin="8,16,0,8"
                                   x:Name="AdminSection"/>

                        <Button x:Name="NavBulkOps" Content="📤  Bulk Operations"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="BulkOps" Click="NavButton_Click"/>

                        <Button x:Name="NavUsers" Content="👥  User Management"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Users" Click="NavButton_Click"/>

                        <Button x:Name="NavSettings" Content="⚙  Settings"
                                Style="{StaticResource SidebarNavButton}"
                                HorizontalAlignment="Stretch" Margin="0,2"
                                Tag="Settings" Click="NavButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== Main Content Frame ===== -->
        <Grid Grid.Column="1">
            <!-- Top Bar -->
            <Border Height="56" VerticalAlignment="Top"
                    Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                    Panel.ZIndex="10">
                <Grid Margin="24,0">
                    <TextBlock x:Name="PageTitleBar" Text="Dashboard"
                               VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    
                    <!-- Window Controls: Help, Minimize, Maximize/Restore, Close -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="HelpBtn" Content="❓" FontSize="14" 
                                Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"
                                Click="HelpBtn_Click" ToolTip="Help"/>
                        <Button x:Name="MinimizeBtn" Content="─" FontSize="14" 
                                Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"
                                Click="MinimizeBtn_Click" ToolTip="Minimize"/>
                        <Button x:Name="MaximizeBtn" Content="☐" FontSize="14"
                                Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"
                                Click="MaximizeBtn_Click" ToolTip="Maximize"/>
                        <Button x:Name="CloseBtn" Content="✕" FontSize="12"
                                Width="36" Height="28" Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"
                                Click="CloseBtn_Click" ToolTip="Close"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="DateTimeText" VerticalAlignment="Center"
                               HorizontalAlignment="Right" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,120,0"/>
                </Grid>
            </Border>

            <!-- Page Content -->
            <Frame x:Name="MainFrame" Margin="0,56,0,0"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
