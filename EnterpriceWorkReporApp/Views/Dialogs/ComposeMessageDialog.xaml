<Window x:Class="EnterpriseWorkReport.Views.Dialogs.ComposeMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compose Message" Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBgBrush}"
        MinWidth="500" MinHeight="400">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="✉️ Compose New Message" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- To -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="TO *" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="ReceiverCombo" Style="{StaticResource ModernComboBox}" 
                      DisplayMemberPath="FullName" SelectedValuePath="Id"/>
            <CheckBox x:Name="BroadcastCheck" Content="Send to all users (Broadcast)" 
                      Margin="0,8,0,0" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                      Checked="BroadcastCheck_Changed" Unchecked="BroadcastCheck_Changed"/>
        </StackPanel>

        <!-- Subject -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="SUBJECT" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="SubjectBox" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <!-- Message -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="MESSAGE *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="ContentBox" Style="{StaticResource ModernTextBox}"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Height="120"/>
        </StackPanel>

        <!-- Attachment -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="ATTACHMENT (File or Image)" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="AttachmentPath" Grid.Column="0" Style="{StaticResource ModernTextBox}" 
                         IsReadOnly="True"/>
                <Button Grid.Column="1" Content="Browse..." Style="{StaticResource OutlineButton}"
                        Padding="12,8" Margin="8,0,0,0" Click="Browse_Click"/>
            </Grid>
            <TextBlock x:Name="AttachmentInfo" Text="" FontSize="11" 
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                    Padding="16,10" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Send Message" Style="{StaticResource PrimaryButton}"
                    Padding="16,10" Click="Send_Click"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Grid.Row="5" Text="" 
                   Foreground="{StaticResource DangerBrush}" FontSize="12"
                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
    </Grid>
</Window>
