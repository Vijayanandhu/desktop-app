<Window x:Class="EnterpriseWorkReport.Views.Dialogs.ProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project" Width="550" Height="550"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBgBrush}"
        ShowInTaskbar="False"
        MinWidth="450" MinHeight="450">
    <Border Padding="32">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="New Project" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <TextBlock Text="PROJECT NAME *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="DescriptionBox" Style="{StaticResource ModernTextBox}" Height="80"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,16"/>

            <TextBlock Text="BILLING FORMULA" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="FormulaBox" Style="{StaticResource ModernTextBox}"
                     Margin="0,0,0,6"/>
            <TextBlock Text="Example: (CharacterCount / 1000) * Rate"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <CheckBox x:Name="IsActiveCheck" Content="Project is Active" IsChecked="True"
                      FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                        Padding="16,10" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Save Project" Style="{StaticResource PrimaryButton}"
                        Padding="16,10" Click="Save_Click"/>
            </StackPanel>

            <TextBlock x:Name="ErrorText" Text="" Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
