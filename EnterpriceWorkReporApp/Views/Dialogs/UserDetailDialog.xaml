<Window x:Class="EnterpriseWorkReport.Views.Dialogs.UserDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Details" Width="900" Height="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBgBrush}" ShowInTaskbar="False"
        MinWidth="800" MinHeight="600">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with User Info -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar Circle -->
                <Border Grid.Column="0" Width="70" Height="70" CornerRadius="35" 
                        Background="{StaticResource PrimaryBrush}" Margin="0,0,20,0">
                    <TextBlock x:Name="AvatarText" Text="" FontSize="28" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- User Basic Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="FullNameText" Text="" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock x:Name="UsernameText" Text="" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                        <Border x:Name="RoleBadge" Style="{StaticResource BadgePrimary}" Padding="10,3" Margin="0,0,16,0">
                            <TextBlock x:Name="RoleText" Text="" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>
                        <Border x:Name="StatusBadge" Style="{StaticResource BadgeSuccess}" Padding="10,3">
                            <TextBlock x:Name="StatusText" Text="" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#065F46"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Close Button -->
                <Button Grid.Column="2" Content="✕" Width="36" Height="36"
                        Background="Transparent" BorderThickness="0" FontSize="16"
                        Cursor="Hand" VerticalAlignment="Top" Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- Tab Control for Details -->
        <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}">
            <!-- Overview Tab -->
            <TabItem Header="📊 Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Attendance Summary Card -->
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,16">
                            <StackPanel>
                                <TextBlock Text="📅 Attendance" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="PresentDaysText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                        <TextBlock Text="Present" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="AbsentDaysText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource DangerBrush}"/>
                                        <TextBlock Text="Absent" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock Text="This Month" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Leave Summary Card -->
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0,5,16">
                            <StackPanel>
                                <TextBlock Text="🏖️ Leave Balance" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="ApprovedLeaveText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="Approved" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="PendingLeaveText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource WarningBrush}"/>
                                        <TextBlock Text="Pending" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock Text="All Time" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Work Report Summary Card -->
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10,0,0,16">
                            <StackPanel>
                                <TextBlock Text="📝 Work Reports" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="TotalReportsText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="Reports" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="TotalAmountText" Text="₹0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                        <TextBlock Text="Amount" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock Text="This Month" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Quality Report Summary Card -->
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="⭐ Quality Reports" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="AvgQualityText" Text="0%" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="Avg Quality" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="TotalQualityReportsText" Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="Reports" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock Text="All Time" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Error Rate Card -->
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0,5,0">
                            <StackPanel>
                                <TextBlock Text="📉 Error Rate" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <StackPanel>
                                    <TextBlock x:Name="AvgErrorRateText" Text="0%" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="Average Error Rate" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock Text="All Time" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Projects Card -->
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="📁 Projects" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <StackPanel>
                                    <TextBlock x:Name="TotalProjectsText" Text="0" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="Projects Worked" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Border Height="1" Background="#E5E7EB" Margin="0,12,0,12"/>
                                <TextBlock x:Name="ProjectsListText" Text="No projects yet" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Attendance Tab -->
            <TabItem Header="📅 Attendance Details">
                <Border Style="{StaticResource CardBorder}" Margin="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Recent Attendance Records" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <DataGrid x:Name="AttendanceGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime, StringFormat={}{0:HH:mm}}" Width="*"/>
                                <DataGridTextColumn Header="Clock Out" Binding="{Binding ClockOutTime, StringFormat={}{0:HH:mm}}" Width="*"/>
                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Leave Tab -->
            <TabItem Header="🏖️ Leave Requests">
                <Border Style="{StaticResource CardBorder}" Margin="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Leave History" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <DataGrid x:Name="LeaveGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Leave Type" Binding="{Binding LeaveType}" Width="*"/>
                                <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Days" Binding="{Binding Days}" Width="60"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,3" CornerRadius="10" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E5E7EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#374151"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                    <Setter Property="Foreground" Value="#991B1B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Work Reports Tab -->
            <TabItem Header="📝 Work Reports">
                <Border Style="{StaticResource CardBorder}" Margin="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Work Reports and Billing" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="WorkReportsTotalAmount" Text=" - Total: ₹0" FontSize="14"
                                       Foreground="{StaticResource SuccessBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DataGrid x:Name="WorkReportsGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="*"/>
                                <DataGridTextColumn Header="Object ID" Binding="{Binding ObjectId}" Width="*"/>
                                <DataGridTextColumn Header="Amount (₹)" Binding="{Binding BillingAmount, StringFormat={}{0:N2}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Quality Reports Tab -->
            <TabItem Header="⭐ Quality Reports">
                <Border Style="{StaticResource CardBorder}" Margin="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Quality Reports" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Style="{StaticResource BadgePrimary}" Padding="10,3" Margin="16,0,0,0">
                                <TextBlock x:Name="QualitySummaryText" Text="Avg: 0% | Error Rate: 0%" FontSize="11" 
                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                        <DataGrid x:Name="QualityGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                                <DataGridTextColumn Header="Quality Score (%)" Binding="{Binding QualityScore, StringFormat={}{0:N1}}" Width="*"/>
                                <DataGridTextColumn Header="Error Rate (%)" Binding="{Binding ErrorRate, StringFormat={}{0:N2}}" Width="*"/>
                                <DataGridTextColumn Header="Rework Count" Binding="{Binding ReworkCount}" Width="*"/>
                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Projects Tab -->
            <TabItem Header="📁 Projects">
                <Border Style="{StaticResource CardBorder}" Margin="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Projects Worked On" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <DataGrid x:Name="ProjectsGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                                  AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Project Name" Binding="{Binding ProjectName}" Width="*"/>
                                <DataGridTextColumn Header="Reports Count" Binding="{Binding ReportsCount}" Width="*"/>
                                <DataGridTextColumn Header="Total Amount (₹)" Binding="{Binding TotalAmount, StringFormat={}{0:N2}}" Width="*"/>
                                <DataGridTextColumn Header="Last Report Date" Binding="{Binding LastReportDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
