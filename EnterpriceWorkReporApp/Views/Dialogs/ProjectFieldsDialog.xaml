<Window x:Class="EnterpriseWorkReport.Views.Dialogs.ProjectFieldsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Project Fields" Width="680" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource AppBgBrush}"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText" Text="Project Fields" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Define the fields that employees fill in when submitting work reports."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <!-- Add Field Form -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="NewFieldLabelBox" Style="{StaticResource ModernTextBox}"
                         Margin="0,0,10,0" Padding="10,8"/>
                <ComboBox Grid.Column="1" x:Name="NewFieldTypeBox" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0">
                    <ComboBoxItem Content="Text" IsSelected="True"/>
                    <ComboBoxItem Content="Number"/>
                </ComboBox>
                <CheckBox Grid.Column="2" x:Name="NewFieldRequired" Content="Required"
                          VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                <CheckBox Grid.Column="3" x:Name="NewFieldBilling" Content="Billing"
                          VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                <Button Grid.Column="4" Content="+ Add Field" Style="{StaticResource PrimaryButton}"
                        Padding="14,9" FontSize="13" Click="AddField_Click"/>
            </Grid>
        </Border>

        <!-- Fields List -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="FieldsGrid" Style="{StaticResource ModernDataGrid}" IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Field Label" Binding="{Binding FieldLabel}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding FieldType}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Required" Binding="{Binding IsRequired}" Width="80"/>
                    <DataGridCheckBoxColumn Header="In Billing" Binding="{Binding IncludeInBilling}" Width="90"/>
                    <DataGridTemplateColumn Header="Delete" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" Tag="{Binding Id}" Style="{StaticResource DangerButton}"
                                        Padding="8,4" FontSize="12" Click="DeleteField_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3" Content="Close" Style="{StaticResource OutlineButton}"
                HorizontalAlignment="Right" Padding="20,10" Margin="0,16,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
