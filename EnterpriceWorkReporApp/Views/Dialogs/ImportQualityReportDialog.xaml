<Window x:Class="EnterpriseWorkReport.Views.Dialogs.ImportQualityReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Quality Report" Height="680" Width="860"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource AppBgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- File picker + date -->
            <RowDefinition Height="Auto"/>  <!-- Preview label -->
            <RowDefinition Height="Auto"/>  <!-- Column mapping header -->
            <RowDefinition Height="*"/>     <!-- Mapping scroll -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Import Quality Report" Style="{StaticResource PageTitle}"/>
            <TextBlock Style="{StaticResource PageSubtitle}"
                       Text="Supports CSV and Excel (.xlsx/.xls). Map each column to its system field — different projects may have different headers."/>
        </StackPanel>

        <!-- File picker + date row -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,10">
            <StackPanel>
                <!-- File -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBox  Grid.Column="1" x:Name="FilePathBox"
                              Style="{StaticResource ModernTextBox}"
                              IsReadOnly="True" Padding="10,8"/>
                    <Button   Grid.Column="2" Content="📂 Browse…"
                              Style="{StaticResource PrimaryButton}"
                              Padding="14,8" Margin="10,0,0,0"
                              Click="Browse_Click"/>
                </Grid>
                <!-- Report date override -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Report Date (override):" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <DatePicker x:Name="ReportDatePicker" Width="150"
                                ToolTip="Used when the file has no date column. Defaults to today."/>
                    <TextBlock Text="  (leave blank = use today or date from file)"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Preview label -->
        <TextBlock Grid.Row="2" x:Name="PreviewLabel"
                   Text="No file selected."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,10" FontStyle="Italic"/>

        <!-- Mapping section header -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="12,10" Margin="0,0,0,4">
            <TextBlock Text="Column Mapping  —  each row shows one column from your file. Choose what it means:"
                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </Border>

        <!-- Scrollable mapping area -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MappingPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="⬆ Import" Style="{StaticResource SuccessButton}"
                    Padding="22,10" Margin="0,0,10,0" Click="Import_Click"/>
            <Button Content="Cancel"   Style="{StaticResource OutlineButton}"
                    Padding="18,10" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
