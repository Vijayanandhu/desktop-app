<Window x:Class="EnterpriseWorkReport.Views.Dialogs.AttendanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mark Attendance" Width="450" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBgBrush}" ShowInTaskbar="False">
    <Border Padding="32">
        <StackPanel>
            <TextBlock Text="Mark Attendance" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <TextBlock Text="EMPLOYEE *" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="EmployeeCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16"/>

            <TextBlock Text="DATE *" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="AttendanceDate" Margin="0,0,0,16"/>

            <TextBlock Text="STATUS *" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="StatusCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
                <ComboBoxItem Content="Present" IsSelected="True"/>
                <ComboBoxItem Content="Absent"/>
                <ComboBoxItem Content="Half Day"/>
                <ComboBoxItem Content="Leave"/>
            </ComboBox>

            <TextBlock Text="REMARKS" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="RemarksBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                        Padding="16,10" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Save" Style="{StaticResource PrimaryButton}"
                        Padding="16,10" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
