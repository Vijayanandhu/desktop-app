<Window x:Class="EnterpriseWorkReport.Views.Dialogs.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User" Width="480" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBgBrush}" ShowInTaskbar="False"
        MinWidth="400" MinHeight="400">
    <Border Padding="32">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="New User" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <TextBlock Text="FULL NAME *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="FullNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

            <TextBlock Text="USERNAME *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

            <TextBlock Text="PASSWORD *" Style="{StaticResource FieldLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="PasswordBox" Grid.Column="0" Style="{StaticResource ModernPasswordBox}"/>
                <Button Grid.Column="1" Content="🎲" Width="40" Margin="8,0,0,0" 
                        Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand"
                        ToolTip="Generate Password" Click="GeneratePassword_Click"/>
            </Grid>
            <TextBlock x:Name="GeneratedPasswordText" Text="" FontSize="11" 
                       Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,14"/>

            <TextBlock Text="ROLE *" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="RoleCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,20">
                <ComboBoxItem Content="Employee" IsSelected="True"/>
                <ComboBoxItem Content="Administrator"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                        Padding="16,10" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Save User" Style="{StaticResource PrimaryButton}"
                        Padding="16,10" Click="Save_Click"/>
            </StackPanel>
            <TextBlock x:Name="ErrorText" Text="" Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Window>
