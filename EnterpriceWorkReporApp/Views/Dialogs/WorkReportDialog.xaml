<Window x:Class="EnterpriseWorkReport.Views.Dialogs.WorkReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Report" Width="550" Height="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBgBrush}" ShowInTaskbar="False">
    <Border Padding="32">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="Submit Work Report" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

            <TextBlock Text="PROJECT *" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="ProjectCombo" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16"
                      SelectionChanged="Project_SelectionChanged"/>

            <TextBlock Text="OBJECT ID *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="ObjectIdBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

            <TextBlock Text="DATE *" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="ReportDate" Margin="0,0,0,16"/>

            <!-- Dynamic Field Container -->
            <StackPanel x:Name="DynamicFieldsPanel"/>

            <TextBlock Text="BILLING AMOUNT (₹)" Style="{StaticResource FieldLabel}" Margin="0,16,0,6"/>
            <TextBox x:Name="BillingBox" Style="{StaticResource ModernTextBox}" IsReadOnly="True"
                     Background="#F9FAFB" Margin="0,0,0,8"/>
                     
            <StackPanel x:Name="AdminNotePanel" Margin="0,0,0,16">
                <TextBlock Text="ADMIN NOTES" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="AdminNoteBox" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>

            <!-- Attachment Section -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="ATTACHMENT" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AttachFileBtn" Content="📎 Attach File" Style="{StaticResource OutlineButton}"
                            Padding="12,6" FontSize="11" Click="AttachFile_Click"/>
                    <TextBlock x:Name="AttachmentNameText" Text="No file attached" 
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button x:Name="RemoveAttachmentBtn" Content="✕" Style="{StaticResource LinkButton}"
                            Foreground="{DynamicResource DangerBrush}" Margin="8,0,0,0"
                            Visibility="Collapsed" Click="RemoveAttachment_Click"
                            ToolTip="Remove attachment"/>
                </StackPanel>
            </StackPanel>
            <Button Content="⚙ Calculate Billing" Style="{StaticResource OutlineButton}"
                    Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                    Margin="0,0,0,24" Click="CalculateBilling_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="AddAnotherCheck" Content="Add another report after saving" 
                          VerticalAlignment="Center" Margin="0,0,20,0" FontSize="12"
                          Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                        Padding="16,10" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Save Report" Style="{StaticResource PrimaryButton}"
                        Padding="16,10" Click="Save_Click"/>
            </StackPanel>

            <TextBlock x:Name="ErrorText" Text="" Foreground="{StaticResource DangerBrush}"
                       FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
