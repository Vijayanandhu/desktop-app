<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color Palette ===== -->

    <!-- Primary Brand -->
    <Color x:Key="PrimaryColor">#3B5BDB</Color>
    <Color x:Key="PrimaryDarkColor">#2F4BC5</Color>
    <Color x:Key="PrimaryLightColor">#EEF2FF</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#7048E8</Color>

    <!-- Backgrounds -->
    <Color x:Key="SidebarBgColor">#1A1D2E</Color>
    <Color x:Key="SidebarHoverColor">#2A2E45</Color>
    <Color x:Key="AppBgColor">#F0F2F8</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#131722</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>
    <Color x:Key="SidebarTextColor">#A0AEC0</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#E5E7EB</Color>

    <!-- ===== Solid Color Brushes ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimary}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="BorderBrush_" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
