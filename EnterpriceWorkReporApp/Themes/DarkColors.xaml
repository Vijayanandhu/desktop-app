<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Deep Navy - Dark Theme ===== -->

    <!-- Primary Brand -->
    <Color x:Key="PrimaryColor">#4C6EF5</Color>
    <Color x:Key="PrimaryDarkColor">#3B5BDB</Color>
    <Color x:Key="PrimaryLightColor">#1C2237</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#845EF7</Color>

    <!-- Backgrounds -->
    <Color x:Key="SidebarBgColor">#0F111A</Color>
    <Color x:Key="SidebarHoverColor">#1C1E2B</Color>
    <Color x:Key="AppBgColor">#131521</Color>
    <Color x:Key="CardBgColor">#1A1D2E</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E2E8F0</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>
    <Color x:Key="SidebarTextColor">#71799E</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#2D3348</Color>

    <!-- ===== Solid Color Brushes ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{DynamicResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{DynamicResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{DynamicResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="AppBgBrush" Color="{DynamicResource AppBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{DynamicResource CardBgColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{DynamicResource TextOnPrimary}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{DynamicResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{DynamicResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="BorderBrush_" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
